-- main.gig

local clicks = 0
local power = 1

function game_load()
    print("Game loaded!")
end

function game_update(dt)
    clicks = clicks + power * dt
end

function game_draw()
    graphics.clear(0.1, 0.2, 0.3)
    graphics.draw_text("Clicks: " .. clicks, 10, 10, 20)
    graphics.draw_circle(400, 300, 50, "green")
    graphics.draw_rect(10, 50, 100, 30, "blue")
end
