entry game {
    var score = 0
    var power = 1
    var mainButton = Rect(200, 400, 600, 600)

    loop {
        render->clear(0.1, 0.1, 0.2)
        render->text("SCORE: " + score, 50, 100, 2.0)
        render->drawRect(mainButton, color.Green)

        if input->tapped(mainButton) {
            score = score + power
        }
    }
}
